{
    "name": "jrlom/gerenciador-de-estoque",
    "description": "Brasallis ERP — Sistema de gestão empresarial cloud-ready em PHP.",
    "type": "project",
    "authors": [
        {
            "name": "jrlom"
        }
    ],
    "require": {
        "php": ">=8.0",
        "phpmailer/phpmailer": "^7.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "up": [
            "docker-compose up -d",
            "docker exec brasallis-server composer install"
        ],
        "setup": [
            "docker exec brasallis-server php setup_master.php"
        ],
        "down": "docker-compose down",
        "terminal": "docker exec -it brasallis-server bash",
        "db-reset": [
            "@down",
            "@up",
            "@setup"
        ],
        "test": "phpunit"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
